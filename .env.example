# Banco de dados PostgreSQL
# Local: postgresql://user:senha@localhost:5432/bijuteria
# Railway: ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:senha@localhost:5432/bijuteria"

# Autenticação (NextAuth)
# Gere um segredo com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-este-segredo-em-producao"

# URL pública do app (em produção use a URL do Railway)
NEXTAUTH_URL="http://localhost:3000"
