# Banco de dados PostgreSQL
# Local: postgresql://user:senha@localhost:5432/bijuteria
# Railway: ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:senha@localhost:5432/bijuteria"

# Autenticação (NextAuth)
# Gere um segredo com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-este-segredo-em-producao"

# URL pública do app (em produção use a URL do Railway)
NEXTAUTH_URL="http://localhost:3000"

# URL pública do app (usada nos back_urls/notification_url do gateway)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Senha inicial do admin (aplicada só na criação via /api/setup)
ADMIN_INITIAL_PASSWORD="troque-esta-senha-forte"

# Mercado Pago (Checkout Pro)
# Access Token de Produção (painel MP > Suas integrações > Credenciais)
MP_ACCESS_TOKEN=""
# Assinatura secreta do webhook (painel MP > Webhooks)
MP_WEBHOOK_SECRET=""
